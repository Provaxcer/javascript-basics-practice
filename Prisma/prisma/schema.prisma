generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int         @id @default(autoincrement())
  email     String      @unique
  watchlist Watchlist[]
}

model Watchlist {
  id          Int    @id @default(autoincrement())
  stockSymbol String
  userId      Int
  user        User   @relation(fields: [userId], references: [id])
}

model Stock {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique
  price     Float
  updatedAt DateTime @default(now())
}